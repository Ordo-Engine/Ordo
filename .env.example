# Copy this to .env and fill in values before running `docker compose up` or `make dev`.
#
#   cp .env.example .env
#
# .env is gitignored — NEVER commit real secrets.
#
# ╔══════════════════════════════════════════════════════════════════════════╗
# ║  CHANGE EVERY VALUE IN THE "SECURITY-CRITICAL" SECTION BEFORE DEPLOYING    ║
# ║  ANYWHERE THAT IS NOT YOUR LOCAL MACHINE. The compose defaults are         ║
# ║  insecure dev placeholders.                                                ║
# ╚══════════════════════════════════════════════════════════════════════════╝

# ── SECURITY-CRITICAL (change for anything beyond local dev) ───────────────────

# Platform JWT signing secret — MUST be at least 32 characters and high-entropy.
# Anyone who knows this can forge auth tokens for every tenant.
#   generate: openssl rand -hex 32
ORDO_JWT_SECRET=change-me-to-a-random-32-char-secret

# PostgreSQL password for the platform database (compose `postgres` service and
# the ORDO_DATABASE_URL used by ordo-platform / ordo-platform-worker).
#   generate: openssl rand -hex 24
ORDO_DB_PASSWORD=ordo_dev_pass

# Shared token ordo-server presents when registering with ordo-platform.
#   generate: openssl rand -hex 32
ORDO_SERVER_TOKEN=dev-server-token-change-in-prod

# Allowed CORS origins for the platform (comma-separated). NEVER use "*" in
# production — scope it to your real Studio / frontend origin(s).
# ORDO_PLATFORM_CORS_ORIGINS=https://studio.example.com

# ── GitHub OAuth (optional — leave blank to disable OAuth login) ───────────────
# Register the callback URL below in your GitHub OAuth App settings exactly.
ORDO_GITHUB_CLIENT_ID=
ORDO_GITHUB_CLIENT_SECRET=
ORDO_GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/github/callback

# ── Non-secret overrides (defaults are set in compose.yml) ─────────────────────
# Platform listen address (default: 0.0.0.0:3001 in compose; binary default 3000)
# ORDO_PLATFORM_ADDR=0.0.0.0:3001
# JWT expiry in hours (default: 24)
# ORDO_JWT_EXPIRY_HOURS=24
# Studio dev-server host port (default: 3002)
# ORDO_STUDIO_PORT=3002

# ── ordo-server (set in compose.yml; override only if needed) ──────────────────
# ORDO_HTTP_ADDR=0.0.0.0:8080
# ORDO_RULES_DIR=/data/rules
#
# Full ORDO_* reference: deploy/CONFIGURATION.md
