# Copy this to .env and fill in values before running docker compose or make dev
#
# .env is gitignored — never commit secrets.

# ── ordo-platform ─────────────────────────────────────────────────────────────
# JWT signing secret — must be at least 32 characters
ORDO_JWT_SECRET=change-me-to-a-random-32-char-secret

# Listen address for the platform HTTP server (default: 0.0.0.0:3001)
# ORDO_PLATFORM_ADDR=0.0.0.0:3001

# JWT expiry in hours (default: 24)
# ORDO_JWT_EXPIRY_HOURS=24

# GitHub OAuth App credentials for Marketplace / GitHub template install
# Register the callback URL below in your GitHub OAuth App settings exactly.
ORDO_GITHUB_CLIENT_ID=
ORDO_GITHUB_CLIENT_SECRET=
ORDO_GITHUB_CALLBACK_URL=http://localhost:3001/api/v1/github/callback

# ── ordo-server ───────────────────────────────────────────────────────────────
# These are set in compose.yml and usually don't need overriding for dev.
# ORDO_ADDR=0.0.0.0:8080
# ORDO_RULES_DIR=/data/rules
