{
  "name": "@ordo-engine/wasm",
  "version": "0.4.2",
  "description": "WebAssembly bindings for Ordo Rule Engine",
  "type": "module",
  "main": "./index.js",
  "types": "./index.d.ts",
  "exports": {
    ".": {
      "import": "./index.js",
      "types": "./index.d.ts"
    },
    "./dist/*": "./dist/*"
  },
  "files": [
    "dist",
    "index.js",
    "index.d.ts",
    "stub.js",
    "stub.d.ts"
  ],
  "scripts": {
    "build": "pnpm build:wasm",
    "build:wasm": "cd ../../../crates/ordo-wasm && ./build.sh",
    "build:stub": "echo 'Using stub module'",
    "clean": "rm -rf dist"
  },
  "keywords": [
    "ordo",
    "rule-engine",
    "wasm",
    "webassembly"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/Ordo-Engine/Ordo.git",
    "directory": "ordo-editor/packages/wasm"
  },
  "publishConfig": {
    "access": "public"
  }
}
